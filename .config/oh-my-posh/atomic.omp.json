{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#61afef",
          "foreground": "#282c34",
          "leading_diamond": "╭─",
          "style": "diamond",
          "template": " {{ .Name }} ",
          "type": "shell"
        },
        {
          "background": "#e06c75",
          "foreground": "#abb2bf",
          "style": "diamond",
          "template": "<parentBackground></>  ",
          "type": "root"
        },
        {
          "background": "#d19a66",
          "foreground": "#282c34",
          "powerline_symbol": "",
          "options": {
            "folder_icon": "  ",
            "home_icon": "",
            "style": "folder"
          },
          "style": "powerline",
          "template": "  {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#e5c07b",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#e06c75{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#56b6c2{{ end }}",
            "{{ if gt .Ahead 0 }}#c678dd{{ end }}",
            "{{ if gt .Behind 0 }}#c678dd{{ end }}"
          ],
          "foreground": "#282c34",
          "powerline_symbol": "",
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#e06c75>  {{ .Staging.String }}</>{{ end }} ",
          "type": "git"
        },
        {
          "background": "#5c6370",
          "foreground": "#abb2bf",
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": "  {{ .FormattedMs }} ",
          "trailing_diamond": "",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#2c313a",
          "foreground": "#abb2bf",
          "leading_diamond": "",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": " <#e06c75></> ",
            "yarn_icon": " <#56b6c2></>"
          },
          "style": "diamond",
          "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "trailing_diamond": " ",
          "type": "node"
        },
        {
          "background": "#61afef",
          "foreground": "#282c34",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "python"
        },
        {
          "background": "#56b6c2",
          "foreground": "#282c34",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "java"
        },
        {
          "background": "#21252b",
          "foreground": "#abb2bf",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ if .Unsupported }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "dotnet"
        },
        {
          "background": "#d19a66",
          "foreground": "#282c34",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "go"
        },
        {
          "background": "#e5c07b",
          "foreground": "#282c34",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "rust"
        },
        {
          "background": "#56b6c2",
          "foreground": "#282c34",
          "leading_diamond": " ",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "dart"
        },
        {
          "background": "#e06c75",
          "foreground": "#abb2bf",
          "leading_diamond": " ",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "angular"
        },
        {
          "background": "#c678dd",
          "foreground": "#282c34",
          "leading_diamond": " ",
          "style": "diamond",
          "template": "α {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "aurelia"
        },
        {
          "background": "#2c313a",
          "foreground": "#abb2bf",
          "leading_diamond": " ",
          "style": "diamond",
          "template": "{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "nx"
        },
        {
          "background": "#61afef",
          "foreground": "#282c34",
          "leading_diamond": " ",
          "style": "diamond",
          "template": "<#e06c75></> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "julia"
        },
        {
          "background": "#4b5263",
          "foreground": "#abb2bf",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "ruby"
        },
        {
          "background": "#56b6c2",
          "foreground": "#282c34",
          "leading_diamond": "",
          "style": "diamond",
          "template": "<#e5c07b></> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": " ",
          "type": "azfunc"
        },
        {
          "background": "#5c6370",
          "foreground": "#abb2bf",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{.Profile}}{{if .Region}}@{{.Region}}{{end}}",
          "trailing_diamond": " ",
          "type": "aws"
        },
        {
          "background": "#61afef",
          "foreground": "#282c34",
          "leading_diamond": "",
          "style": "diamond",
          "template": " {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}",
          "trailing_diamond": "",
          "type": "kubectl"
        },
        {
          "background": "#4b5263",
          "foreground": "#abb2bf",
          "leading_diamond": "",
          "trailing_diamond": "<transparent,background></>",
          "options": {
            "linux": "",
            "macos": "",
            "windows": ""
          },
          "style": "diamond",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#e06c75",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#61afef{{end}}",
            "{{if eq \"Discharging\" .State.String}}#e5c07b{{end}}",
            "{{if eq \"Full\" .State.String}}#98c379{{end}}"
          ],
          "foreground": "#282c34",
          "invert_powerline": true,
          "powerline_symbol": "",
          "options": {
            "charged_icon": " ",
            "charging_icon": " ",
            "discharging_icon": " "
          },
          "style": "powerline",
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }} ",
          "type": "battery"
        },
        {
          "background": "#c678dd",
          "foreground": "#282c34",
          "invert_powerline": true,
          "leading_diamond": "",
          "options": {
            "time_format": "_2,15:04"
          },
          "style": "diamond",
          "template": "  {{ .CurrentDate | date .Format }} ",
          "trailing_diamond": "",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#5c6370",
          "style": "plain",
          "template": "╰─",
          "type": "text"
        },
        {
          "foreground": "#abb2bf",
          "foreground_templates": ["{{ if gt .Code 0 }}#e06c75{{ end }}"],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": " ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
